# .devcontainer/.env — Project-level DevContainer environment overrides
#
# This file is committed to the repository and applies to everyone working on
# this project. Use it to set project-wide defaults that differ from the
# blueprint's built-in defaults in devcontainer.json.
#
# For personal or machine-specific overrides that should NOT be committed,
# copy .devcontainer/.env.local.example to .devcontainer/.env.local instead.
# Values in .env.local always take precedence over this file.
#
# After changing this file, run "Dev Containers: Rebuild Container" to apply.
#
# ⚠ SCOPE LIMITATION: Variables in this file are available to lifecycle hook scripts
# (onCreateCommand, postCreateCommand, etc.) and interactive shell sessions.
# They are NOT available to:
#   - DevContainer features (installed during image build, before container start)
#   - containerEnv (set by Docker runtime, independently of this file)
# For feature configuration (e.g. Python/Node version), edit devcontainer.json directly.
# For Python runtime flags (PYTHONASYNCIODEBUG etc.), use containerEnv in devcontainer.json.
#
# Script configuration — these are read by script/setup/bootstrap (and friends) only.
#
# Install HACS in the Home Assistant installation (default: "1" = install).
HA_INSTALL_HACS=1
#
# Run apt-get update/upgrade during setup (default: "0" = skip).
APT_UPDATE=0
#
# Pin to a specific Home Assistant version (default: version from hacs.json).
# Supported values:
#   "latest"         → newest stable release
#   "beta"           → newest pre-release (alpha/beta/RC)
#   "YEAR.MONTH"     → latest patch for that month (e.g. "2026.4")
#   "YEAR.MONTH.0"   → same as above (hacs.json minimum → resolved to latest patch)
#   "YEAR.MONTH.N"   → exact stable version (e.g. "2026.4.2")
#   "YEAR.MONTH.NbM" → exact pre-release (e.g. "2026.4.0b1")
# HA_VERSION=2026.4
